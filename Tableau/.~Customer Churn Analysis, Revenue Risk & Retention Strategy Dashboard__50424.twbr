                </zone>
              </zone>
              <zone fixed-size='169' h='16015' id='26' is-fixed='true' layout-strategy-id='distribute-evenly' param='horz' type-v2='layout-flow' w='98828' x='586' y='66667'>
                <zone fixed-size='515' h='16015' id='27' is-fixed='true' name='Churn by Gender' w='49414' x='586' y='66667'>
                  <layout-cache fixed-size-h='104' minwidth='180' type-h='fixed' type-w='scalable' />
                  <zone-style>
