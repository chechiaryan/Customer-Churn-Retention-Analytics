                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='115' h='16015' id='27' is-fixed='true' name='Churn by Gender' w='49414' x='586' y='66667'>
                  <layout-cache fixed-size-h='104' minwidth='180' type-h='fixed' type-w='scalable' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='115' h='16015' id='36' is-fixed='true' name='Active vs Inactive Members' w='49414' x='50000' y='66667'>
                  <layout-cache has-max-size-w='true' maxwidth='1073' minwidth='1073' type-h='fixed' type-w='scalable' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16276' id='37' type-v2='text' w='49414' x='586' y='82682'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Key Findings </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Overall churn rate stands at </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>20.37%</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>• Germany records the highest churn rate (</run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>32.44%</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>)</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>• Senior customers represent the highest-risk segment (</run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>45.45%</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>)</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>• Inactive members are nearly </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>2x more likely</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> to churn</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>• Customers holding </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>3+ products</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> exhibit exceptionally high attrition</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>• Female customers show higher churn compared to male customers </run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='solid' />
                    <format attr='border-width' value='1' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='16276' id='39' type-v2='text' w='49414' x='50000' y='82682'>
                  <formatted-text>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Recommendation </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Prioritize retention initiatives for </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Germany-based customers</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>, </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>senior customers</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>, and </run>
                    <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>inactive members</run>
                    <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'> through targeted engagement campaigns, loyalty programs, and proactive customer support strategies. </run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='solid' />
                    <format attr='border-width' value='1' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
