      <aliases enabled='yes' />
      <column caption='Total Customers' datatype='integer' name='[Calculation_3465121684815872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([CustomerId])' />
      </column>
      <column caption='Churned Customers' datatype='integer' name='[Calculation_3465121685856257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Exited] = 1 THEN 1 END' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_3465121686298626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Exited]) / COUNT([CustomerId])' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_3465121686683651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([Exited]) / COUNT([CustomerId]))' />
      </column>
      <column caption='Retained Customers' datatype='integer' name='[Calculation_3465121904013316]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Exited] = 0 THEN 1 END' />
      </column>
      <column caption='Member Status' datatype='string' name='[Calculation_3465121910759429]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [IsActiveMember] = 1 THEN &quot;Active&quot;&#10;ELSE &quot;Inactive&quot;&#10;END' />
      </column>
      <column caption='Revenue At Risk' datatype='real' name='[Calculation_3465121974521862]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Exited] = 1 THEN [Balance] END' />
      </column>
      <column caption='Churned Balance' datatype='real' name='[Calculation_3465121975267335]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Exited] = 1 THEN [Balance] END' />
      </column>
      <column caption='High Value Customers Lost' datatype='integer' name='[Calculation_3465121976033288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Balance] &gt; 100000&#10;AND [Exited] = 1&#10;THEN 1&#10;END' />
      </column>
      <column caption='Churn %' datatype='real' name='[Calculation_3465121976774665]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Exited])' />
      </column>
      <column caption='Salary Segment ' datatype='string' name='[Calculation_3465121980997642]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [EstimatedSalary] &lt; 50000 THEN &quot;Low Salary&quot;&#10;&#10;ELSEIF [EstimatedSalary] &lt; 100000 THEN &quot;Medium Salary&quot;&#10;&#10;ELSE &quot;High Salary&quot;&#10;&#10;END' />
      </column>
      <column caption='Credit Score Segment' datatype='string' name='[Calculation_3465121982115851]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Poor&quot;&#10;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Fair&quot;&#10;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Good&quot;&#10;&#10;ELSE &quot;Excellent&quot;&#10;&#10;END' />
      </column>
      <column caption='Highest Risk Segment' datatype='string' name='[Calculation_3465122005135372]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;4 Products (100%)&quot;' />
      </column>
      <column caption='Lowest Risk Segment ' datatype='string' name='[Calculation_3465122005700621]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;2 Products (7.58%)&quot;' />
      </column>
