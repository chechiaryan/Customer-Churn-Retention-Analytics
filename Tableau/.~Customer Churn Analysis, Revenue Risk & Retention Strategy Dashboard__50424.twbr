                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='151' h='20703' id='30' is-fixed='true' name='Churn by Products' w='49414' x='586' y='45964'>
                  <layout-cache has-max-size-w='true' maxwidth='1038' minwidth='1038' type-h='cell' type-w='scalable' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
