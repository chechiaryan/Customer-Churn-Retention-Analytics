    <worksheet name='Credit Score vs Churn'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Book' fontsize='16'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Churn_Cleaned' name='federated.1xn7li6108xxvg1bs9xgb16e62wj' />
          </datasources>
          <datasource-dependencies datasource='federated.1xn7li6108xxvg1bs9xgb16e62wj'>
            <column caption='Churn %' datatype='real' name='[Calculation_3465121976774665]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Exited])' />
            </column>
            <column caption='Credit Score Segment' datatype='string' name='[Calculation_3465121982115851]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [CreditScore] &lt; 500 THEN &quot;Poor&quot;&#10;&#10;ELSEIF [CreditScore] &lt; 650 THEN &quot;Fair&quot;&#10;&#10;ELSEIF [CreditScore] &lt; 750 THEN &quot;Good&quot;&#10;&#10;ELSE &quot;Excellent&quot;&#10;&#10;END' />
            </column>
            <column caption='Credit Score' datatype='integer' name='[CreditScore]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Exited]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_3465121982115851]' derivation='None' name='[none:Calculation_3465121982115851:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3465121976774665]' derivation='User' name='[usr:Calculation_3465121976774665:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
