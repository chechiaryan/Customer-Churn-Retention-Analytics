                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='151' h='20703' id='31' is-fixed='true' name='Churn by Balance Segment' w='49414' x='50000' y='45964'>
                  <layout-cache minwidth='200' type-h='cell' type-w='scalable' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
