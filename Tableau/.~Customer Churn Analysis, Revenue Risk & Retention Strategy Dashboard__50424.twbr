    <worksheet name='Customer Risk Segmentation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Book' fontsize='16'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Churn_Cleaned' name='federated.1xn7li6108xxvg1bs9xgb16e62wj' />
          </datasources>
          <datasource-dependencies datasource='federated.1xn7li6108xxvg1bs9xgb16e62wj'>
            <column caption='Risk Category' datatype='string' name='[Calculation_3465122007810063]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [NumOfProducts] &gt;= 3 THEN &quot;High Risk&quot;&#10;&#10;ELSEIF [NumOfProducts] = 2 THEN &quot;Low Risk&quot;&#10;&#10;ELSE &quot;Medium Risk&quot;&#10;&#10;END' />
            </column>
            <column caption='Customer Id' datatype='integer' name='[CustomerId]' role='dimension' type='ordinal' />
            <column caption='Num Of Products' datatype='integer' name='[NumOfProducts]' role='measure' type='quantitative'>
              <aliases>
                <alias key='1' value='1 Product' />
                <alias key='2' value='2 Products' />
                <alias key='3' value='3 Products' />
                <alias key='4' value=' 4 Products' />
              </aliases>
            </column>
            <column-instance column='[CustomerId]' derivation='Count' name='[cnt:CustomerId:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_3465122007810063]' derivation='None' name='[none:Calculation_3465122007810063:nk]' pivot='key' type='nominal' />
            <column-instance column='[CustomerId]' derivation='None' name='[none:CustomerId:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <manual-sort column='[federated.1xn7li6108xxvg1bs9xgb16e62wj].[none:Calculation_3465122007810063:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;High Risk&quot;</bucket>
              <bucket>&quot;Medium Risk&quot;</bucket>
              <bucket>&quot;Low Risk&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.1xn7li6108xxvg1bs9xgb16e62wj].[none:CustomerId:ok]'>
            <groupfilter function='level-members' level='[none:CustomerId:ok]' user:ui-manual-selection='true' user:ui-manual-selection-is-empty='true' user:ui-marker='enumerate' />
          </filter>
          <slices>
            <column>[federated.1xn7li6108xxvg1bs9xgb16e62wj].[none:CustomerId:ok]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <format attr='display' class='0' field='[federated.1xn7li6108xxvg1bs9xgb16e62wj].[cnt:CustomerId:qk]' scope='cols' value='false' />
          </style-rule>
        </style>
        <panes>
