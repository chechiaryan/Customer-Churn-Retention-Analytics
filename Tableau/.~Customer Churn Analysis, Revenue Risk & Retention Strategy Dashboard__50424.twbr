    <worksheet name='Salary vs Churn'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Tableau Book' fontsize='16'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Churn_Cleaned' name='federated.1xn7li6108xxvg1bs9xgb16e62wj' />
          </datasources>
          <datasource-dependencies datasource='federated.1xn7li6108xxvg1bs9xgb16e62wj'>
            <column caption='Churn %' datatype='real' name='[Calculation_3465121976774665]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Exited])' />
            </column>
            <column caption='Salary Segment ' datatype='string' name='[Calculation_3465121980997642]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [EstimatedSalary] &lt; 50000 THEN &quot;Low Salary&quot;&#10;&#10;ELSEIF [EstimatedSalary] &lt; 100000 THEN &quot;Medium Salary&quot;&#10;&#10;ELSE &quot;High Salary&quot;&#10;&#10;END' />
            </column>
            <column caption='Estimated Salary' datatype='real' name='[EstimatedSalary]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Exited]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_3465121980997642]' derivation='None' name='[none:Calculation_3465121980997642:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_3465121976774665]' derivation='User' name='[usr:Calculation_3465121976774665:qk]' pivot='key' type='quantitative' />
